using Newtonsoft.Json;
using Newtonsoft.Json.Converters;

namespace WinGPT.OpenAI.Chat;

public class Message_old {
   public Message_old() {
   }

   public Message_old(Role role, string content) {
      this.role    = role;
      this.content = null;
   }

   [JsonConverter(typeof(StringEnumConverter))]
   public Role role { get; init; }

   public ContentPart[] content { get; init; }

   [JsonProperty(NullValueHandling = NullValueHandling.Ignore)]
   public string? name { get; init; }

   /// <summary>
   /// **Not** the same thing as <see cref="Request.function_call"/>.
   /// </summary>
   [JsonProperty(NullValueHandling = NullValueHandling.Ignore)]
   public FunctionCall? function_call { get; init; } = null!;


   public override string ToString() {
      var specialToken = role.ToSpecialToken();
      var text         = specialToken + content + "\r\n";
      return text;
   }

   public Message Clone() {
      return new Message(role, content) {
         name          = name,
         function_call = function_call
      };
   }
}

public class ContentPart {
   public ContentType type { get; init; }
   //public string      text { get; init; } = null!;
}

public class TextContentPart : ContentPart {
   public string text { get; init; }
}

public class ImageContentPart : ContentPart {
   public Image_URL image_url { get; init; }
}

public class Image_URL {
   public string url { get; init; }

   public Image_URL(string url) {
      this.url = url;
   }
}

public enum ContentType {
   text,
   image_url
}

public class FunctionCall {
   public string name      { get; init; } = null!;
   public string arguments { get; init; } = null!;
}